{
  "name": "react-ai-helmet",
  "version": "0.1.0",
  "description": "AI readability toolkit for React — schema components, AI region hints, and a CLI that generates llms.txt, llms-full.txt and robots.txt.",
  "author": "Abdullah Khamis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdullah-khamis/react-ai-helmet.git"
  },
  "homepage": "https://github.com/abdullah-khamis/react-ai-helmet#readme",
  "bugs": {
    "url": "https://github.com/abdullah-khamis/react-ai-helmet/issues"
  },
  "type": "module",
  "sideEffects": false,
  "bin": {
    "react-ai-helmet": "./index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./collect": {
      "import": {
        "types": "./dist/collect.d.ts",
        "default": "./dist/collect.js"
      },
      "require": {
        "types": "./dist/collect.d.cts",
        "default": "./dist/collect.cjs"
      }
    }
  },
  "files": [
    "dist",
    "commands",
    "index.js",
    "logger.js",
    "config.js",
    "scanner.js",
    "manifest.js",
    "llms-generator.js",
    "robots-generator.js",
    "sitemap-generator.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node run-tests.mjs",
    "example:build": "tsup example/src/routes.jsx --no-config --format esm --out-dir example/build --external react --external react-ai-helmet",
    "example": "npm run build && npm run example:build && node example/scripts/collect.mjs && node example/scripts/demo.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "llms.txt",
    "ai",
    "aeo",
    "schema",
    "json-ld",
    "seo",
    "robots.txt"
  ],
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.2.7",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
